# =============================================================================
# Portfolio 2.0 — environment variables (Part 8 of the build spec)
# Copy to `.env.local` and fill in. ALL services below are free, no card required.
# Server-only secrets MUST stay un-prefixed (never NEXT_PUBLIC_) and must never
# be imported from a client component.
# =============================================================================

# --- Supabase (free tier, no card) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Content sync sources (all free, no card) ---
# GitHub: token raises rate limits but public data works unauthenticated too.
GITHUB_TOKEN=
GITHUB_USERNAME=
# Optional: shared secret to verify GitHub webhook signatures (push/release).
GITHUB_WEBHOOK_SECRET=
# YouTube: channel RSS needs no key/quota — set the channel id.
YOUTUBE_CHANNEL_ID=
# YouTube Data API key (free quota) — optional alternative to RSS.
YOUTUBE_API_KEY=
# RSS feeds (Dev.to/Hashnode/Medium), comma-separated feed URLs.
RSS_FEEDS=
# External weekly sources (all optional; comma-separated where plural).
HF_USERNAME=
PYPI_PACKAGES=
NPM_PACKAGES=
ORCID_ID=

# --- AI assistant ---
# Google Gemini API key (free tier, no card) — ai.google.dev
GEMINI_API_KEY=
# Free Flash model (Pro is paid-only since Apr 2026). Override if needed.
GEMINI_MODEL=gemini-2.5-flash
# Hugging Face token for free embeddings (all-MiniLM-L6-v2, 384-dim).
HUGGINGFACE_API_KEY=
# Rate limiter (sized under the verified free Flash ceiling ~15 RPM / 1500 RPD).
GEMINI_GLOBAL_RPM=12
GEMINI_DAILY_BUDGET=1200
CHAT_SESSION_RPM=4
CHAT_SESSION_RPD=40
# Set to 1 only against a provisioned env to run the live AI e2e tests.
E2E_CHAT_ENABLED=

# --- Site ---
# Canonical site URL (used for metadata, sitemap, OG). No card.
NEXT_PUBLIC_SITE_URL=

# --- Analytics (free tier, no card) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Contact ---
CONTACT_NOTIFY_EMAIL=

# --- Internal: shared secret to protect cron/keepalive routes ---
# Generate any random string; set the same value in Vercel project settings.
CRON_SECRET=
